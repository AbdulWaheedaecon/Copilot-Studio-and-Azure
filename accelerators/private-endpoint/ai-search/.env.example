# ============================================================
# Azure AI Search — Private Endpoint + Power Platform
# Copy this file to .env and fill in your values.
# .env is gitignored; this file is the only one checked in.
# ============================================================

# Azure subscription that will host all resources
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Resource group name (created if it doesn't exist)
AZURE_RESOURCE_GROUP=rg-aisearch-pe

# Base name: 3–11 chars, lowercase alphanumerics.
# Used to derive all resource names (VNet, search service, PE, DNS, etc.)
BASE_NAME=pvsrch

# Power Platform geography.
# Allowed: unitedstates | europe | unitedkingdom | japan | australia | asia | singapore | sweden
# This drives the primary and secondary Azure regions automatically.
PP_GEO=unitedstates

# Microsoft Entra tenant ID hosting the Power Platform environment
PP_TENANT_ID=00000000-0000-0000-0000-000000000000

# Power Platform environment GUID (from PPAC → Environments → your env → Environment ID).
# NOT the org URL.
PP_ENVIRONMENT_ID=00000000-0000-0000-0000-000000000000

# ------------------------------------------------------------
# AI Search — new or existing service
# ------------------------------------------------------------

# Set to 'true' to provision a new Azure AI Search service.
# Set to 'false' to put a private endpoint in front of an existing service.
PROVISION_AI_SEARCH=true

# Only required when PROVISION_AI_SEARCH=false.
# Full ARM resource ID of the existing search service.
# Example: /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Search/searchServices/<name>
EXISTING_AI_SEARCH_RESOURCE_ID=

# SKU for the new search service.
# Allowed: basic | standard | standard2 | standard3 | storage_optimized_l1 | storage_optimized_l2
# Note: 'free' is NOT supported — it does not allow private endpoints.
AI_SEARCH_SKU=basic

# ------------------------------------------------------------
# Sample Data — optional index with health-plan PDFs
# ------------------------------------------------------------

# Set to 'true' to provision a storage account, download sample PDFs from
# https://github.com/Azure-Samples/azure-search-sample-data/tree/main/health-plan,
# and create an index + indexer with those documents.
# Useful for quickly testing the custom connector end-to-end.
DEPLOY_SAMPLE_DATA=false

# ------------------------------------------------------------
# Networking — VNet provisioning
# ------------------------------------------------------------

# Set to 'true' (default) to create new VNets with subnets.
# Set to 'false' to use existing VNets — fill in the EXISTING_* values below.
PROVISION_VNET=true

# --- New VNet settings (used when PROVISION_VNET=true) ---
VNET_ADDRESS_PREFIX=10.60.0.0/16
PE_SUBNET_PREFIX=10.60.1.0/24
PP_SUBNET_PREFIX=10.60.2.0/24

# Secondary VNet (required for multi-region PP geos; ignored for singapore/sweden)
SECONDARY_VNET_ADDRESS_PREFIX=10.61.0.0/16
SECONDARY_PP_SUBNET_PREFIX=10.61.2.0/24

# --- Existing VNet settings (used when PROVISION_VNET=false) ---
# Primary VNet: must already have a PE subnet and a PP-delegated subnet.
# Example: /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Network/virtualNetworks/<name>
EXISTING_VNET_ID=
EXISTING_PE_SUBNET_NAME=snet-pe
EXISTING_PP_SUBNET_NAME=snet-powerplatform

# Secondary VNet: required for multi-region PP geos when PROVISION_VNET=false.
EXISTING_SECONDARY_VNET_ID=
EXISTING_SECONDARY_PP_SUBNET_NAME=snet-powerplatform
